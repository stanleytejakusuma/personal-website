---
// Slim REPL command-bar. Typing a command switches the active tab by
// dispatching a `tab:set` CustomEvent the shell's tab controller listens for.
---

<div class="cmdbar" data-cmdbar>
  <form class="cmdbar__form" data-cmd-form>
    <span class="cmdbar__prompt" aria-hidden="true">visitor@stanley:~$</span>
    <input
      class="cmdbar__input"
      data-cmd-input
      autocomplete="off"
      spellcheck="false"
      inputmode="text"
      aria-label="Type a command: about, experience, projects, musings, resume, contact, help, clear"
      placeholder="try: projects"
    />
  </form>
  <p class="cmdbar__ack" data-cmd-ack aria-live="polite"></p>
</div>

<style>
  .cmdbar {
    font-family: var(--font-mono);
    font-size: clamp(0.82rem, 1.4vw, 0.95rem);
  }

  .cmdbar__form {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 32px;
  }

  .cmdbar__prompt {
    color: var(--color-accent);
    white-space: nowrap;
  }

  .cmdbar__input {
    flex: 1;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--color-fg);
    caret-color: var(--color-accent);
    /* >=16px so iOS Safari doesn't auto-zoom on focus */
    font-size: max(16px, 1em);
  }

  .cmdbar__input::placeholder {
    color: var(--color-muted);
  }

  .cmdbar__ack {
    min-height: 1em;
    margin: 0.2rem 0 0;
    color: var(--color-muted);
    font-size: 0.74rem;
  }
</style>

<script>
  const form = document.querySelector('[data-cmd-form]');
  const input = document.querySelector('[data-cmd-input]');
  const ack = document.querySelector('[data-cmd-ack]');
  const TABS = ['about', 'experience', 'projects', 'musings'];

  const setAck = (text: string) => {
    if (ack instanceof HTMLElement) ack.textContent = text;
  };

  const run = (raw: string) => {
    const trimmed = raw.trim();
    const cmd = trimmed.toLowerCase();
    if (!cmd) return;
    if (TABS.includes(cmd)) {
      window.dispatchEvent(new CustomEvent('tab:set', { detail: cmd }));
      setAck(`-> ${cmd}`);
    } else if (cmd === 'resume' || cmd === 'cat resume') {
      window.location.href = '/resume';
    } else if (cmd === 'contact') {
      setAck('reach me via the icons up top ↗');
    } else if (cmd === 'help') {
      setAck('commands: about, experience, projects, musings, resume, contact, help, clear');
    } else if (cmd === 'clear') {
      setAck('');
    } else if (cmd === 'blog' || cmd === 'writing') {
      window.dispatchEvent(new CustomEvent('tab:set', { detail: 'musings' }));
      setAck('-> musings');
    } else if (cmd === 'ls') {
      setAck('about/ experience/ projects/ musings/');
    } else if (cmd === 'pwd') {
      setAck('/home/stanley');
    } else if (cmd.startsWith('sudo')) {
      setAck('stanley is not in the sudoers file. this incident will be reported.');
    } else if (cmd === 'vim') {
      setAck('you are now stuck in vim. try :q! or just click a tab.');
    } else if (cmd === 'rm' || cmd.startsWith('rm ')) {
      setAck('permission denied: nice try');
    } else if (cmd === 'exit' || cmd === ':q' || cmd === ':q!') {
      setAck('there is no escape. try a tab instead.');
    } else if (cmd === 'cat stanley.json') {
      setAck('see the about tab. it is literally right there');
    } else if (cmd.startsWith('echo ')) {
      setAck(trimmed.slice(5).trim());
    } else if (cmd === 'whoami') {
      setAck('visitor (stanley is the one with the keyboard)');
    } else if (cmd === 'credits') {
      setAck('layout lineage: forgash.io. the tabbed-terminal idea. theme, code, and bad opinions: all mine.');
    } else {
      setAck(`unknown command: ${cmd} (try "help")`);
    }
  };

  if (form instanceof HTMLFormElement && input instanceof HTMLInputElement) {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      run(input.value);
      input.value = '';
    });
  }
</script>
