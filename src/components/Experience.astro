---
// Experience tab: terminal-style timeline. Data shared with /resume.
import { entries } from '../data/experience';
---

<div class="xp">
  <p class="xp__resume"><a href="/resume/">full resume →</a></p>
  {
    entries.map((entry) => (
      <article class="xp__entry">
        <div class="xp__rail">
          <p class="xp__dates">{entry.dates}</p>
          {entry.logo && (
            <img class="xp__logo" src={entry.logo} alt={entry.org} loading="lazy" decoding="async" />
          )}
        </div>
        <div class="xp__body">
          <p class="xp__role">
            {entry.role} <span class="xp__org">· {entry.org}</span>
          </p>
          <ul class="xp__bullets">
            {entry.bullets.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
          {entry.repo && (
            <p class="xp__repo">
              <a href={entry.repo} target="_blank" rel="noopener">view repo ↗</a>
            </p>
          )}
        </div>
      </article>
    ))
  }
</div>

<style>
  .xp {
    max-width: none;
    font-family: var(--font-mono);
  }

  .xp__resume {
    margin: 0 0 0.8rem;
    font-size: 0.78rem;
  }

  .xp__resume a {
    color: var(--color-accent);
  }

  .xp__repo {
    margin: 0.45rem 0 0;
    font-size: 0.74rem;
  }

  .xp__repo a {
    color: var(--color-accent);
  }

  .xp__entry {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1.25rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--color-border);
  }

  .xp__entry:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .xp__dates {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 2;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .xp__rail {
    min-width: 0;
  }

  /* Uniform light chip normalizes the mixed logos (gradient icon, gray
     wordmark, transparent png, svg). Fixed height, natural width; the chip
     stays light in both themes because logos are made for light grounds. */
  .xp__logo {
    display: inline-block;
    height: 22px;
    width: auto;
    max-width: 100%;
    margin-top: 0.65rem;
    padding: 4px 6px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    box-sizing: content-box;
    vertical-align: top;
  }

  .xp__role {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .xp__org {
    color: var(--color-accent);
    font-weight: 500;
  }

  .xp__bullets {
    margin: 0.55rem 0 0;
    padding: 0;
    list-style: none;
    color: color-mix(in srgb, var(--color-fg) 72%, var(--color-muted));
    font-size: 0.84rem;
    line-height: 1.75;
  }

  .xp__bullets li::before {
    margin-right: 0.6ch;
    color: var(--color-accent);
    content: '·';
  }

  .xp__bullets li + li {
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .xp__entry {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
