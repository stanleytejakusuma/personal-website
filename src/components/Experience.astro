---
// Experience tab: terminal-style timeline. Entries marked [placeholder] are
// stand-ins until Stanley's resume lands — replace dates/roles/bullets there.
interface Entry {
  dates: string;
  role: string;
  org: string;
  bullets: string[];
  placeholder?: boolean;
}

const entries: Entry[] = [
  {
    dates: '[YYYY]–now',
    role: 'Independent',
    org: 'data & trading systems',
    bullets: [
      'Research, backtest, and run systematic strategies end to end.',
      'Self-hosted data platform: archivers, pipelines, dashboards.',
    ],
  },
  {
    dates: '[YYYY]–[YYYY]',
    role: '[ROLE]',
    org: 'Flipside Crypto',
    bullets: [
      'Built and maintained on-chain data models (dbt on Snowflake) across 12+ blockchains.',
      '[impact metric]',
    ],
    placeholder: true,
  },
  {
    dates: '[YYYY]–[YYYY]',
    role: '[EARLIER ROLE]',
    org: '[COMPANY]',
    bullets: ['[placeholder]'],
    placeholder: true,
  },
];
---

<div class="xp">
  {
    entries.map((entry) => (
      <article class="xp__entry">
        <p class="xp__dates">{entry.dates}</p>
        <div class="xp__body">
          <p class="xp__role">
            {entry.role} <span class="xp__org">· {entry.org}</span>
            {entry.placeholder && <span class="xp__todo">[placeholder]</span>}
          </p>
          <ul class="xp__bullets">
            {entry.bullets.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        </div>
      </article>
    ))
  }
</div>

<style>
  .xp {
    max-width: 72ch;
    font-family: var(--font-mono);
  }

  .xp__entry {
    display: grid;
    grid-template-columns: 9.5rem minmax(0, 1fr);
    gap: 1.25rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--color-border);
  }

  .xp__entry:last-child {
    border-bottom: 1px solid var(--color-border);
  }

  .xp__dates {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.78rem;
    line-height: 2;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .xp__role {
    margin: 0;
    color: var(--color-fg);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .xp__org {
    color: var(--color-accent);
    font-weight: 500;
  }

  .xp__todo {
    margin-left: 0.6rem;
    color: var(--color-muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .xp__bullets {
    margin: 0.55rem 0 0;
    padding: 0;
    list-style: none;
    color: color-mix(in srgb, var(--color-fg) 72%, var(--color-muted));
    font-size: 0.84rem;
    line-height: 1.75;
  }

  .xp__bullets li::before {
    margin-right: 0.6ch;
    color: var(--color-accent);
    content: '·';
  }

  .xp__bullets li + li {
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .xp__entry {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
