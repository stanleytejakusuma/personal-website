---
import { getCollection } from 'astro:content';

const FILTERS = ['DeFi', 'L1/L2', 'NFT', 'GameFi', 'MEV', 'Research', 'CEX/FinTech', 'Evergreen'];
const VENUES = {
  wagmi: 'Wagmi',
  boiler: 'Boiler',
  personal: 'Personal',
} as const;

const entries = (
  await getCollection('musings', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// pinned "featured" reads — flagged per-post via `featured: true` in frontmatter.
const featured = entries.filter((e) => e.data.featured && !e.data.external);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
});

let currentYear = '';
---

<section class="musings" aria-labelledby="musings-h" data-musings>
  <div class="musings__head">
    <div>
      <p class="mono-label">musings</p>
      <h2 class="section-heading" id="musings-h">Research archive.</h2>
    </div>
    <p class="musings__count" data-mcount role="status">{entries.length} entries</p>
  </div>

  <p class="musings__note">Crypto research written 2021–2024, preserved unedited — not financial advice.</p>

  {featured.length > 0 && (
    <div class="musings__featured">
      <p class="musings__featured-label">★ featured</p>
      <div class="musings__featured-grid">
        {featured.map((e) => (
          <a class="fcard" href={`/musings/${e.id}/`}>
            <span class="fcard__title">{e.data.title}</span>
            <span class="fcard__meta">{VENUES[e.data.venue]} · {dateFormatter.format(e.data.date)}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <input
    class="musings__search"
    type="search"
    data-msearch
    placeholder="search the archive…"
    aria-label="Search musings by title, tag, ticker, venue, or year"
    autocomplete="off"
    spellcheck="false"
  />

  <div class="musings__filters" role="group" aria-label="Filter musings by sector">
    <button class="mfilter is-active" type="button" data-filter="all" aria-pressed="true">All</button>
    {FILTERS.map((filter) => (
      <button class="mfilter" type="button" data-filter={filter} aria-pressed="false">{filter}</button>
    ))}
  </div>

  <div class="musings__table-wrap">
    <table class="musings__table" aria-label="Research archive">
      <thead>
        <tr>
          <th scope="col">date</th>
          <th scope="col">title</th>
          <th scope="col">tags</th>
          <th scope="col">venue</th>
        </tr>
      </thead>
      <tbody>
        {entries.map((entry) => {
          const year = String(entry.data.date.getFullYear());
          const showYear = year !== currentYear;
          currentYear = year;
          const href = entry.data.external ?? `/musings/${entry.id}/`;
          const externalAttrs = entry.data.external
            ? { target: '_blank', rel: 'noopener' }
            : {};
          return (
            <>
              {showYear && (
                <tr class="musings__year" data-year-divider data-year={year}>
                  <th scope="rowgroup" colspan="4">{year}</th>
                </tr>
              )}
              <tr
                class="musings__row"
                data-musing-row
                data-id={entry.id}
                data-year={year}
                data-tags={entry.data.tags.join('|')}
                data-search={[
                  entry.data.title,
                  ...entry.data.tags,
                  ...(entry.data.subtags ?? []),
                  ...(entry.data.tickers ?? []),
                  entry.data.venue,
                  VENUES[entry.data.venue],
                  entry.data.research ? 'research' : '',
                  year,
                ]
                  .join(' ')
                  .toLowerCase()}
              >
                <td class="musings__date" data-label="date">
                  <time datetime={entry.data.date.toISOString()}>{dateFormatter.format(entry.data.date)}</time>
                </td>
                <td class="musings__title" data-label="title">
                  <a href={href} {...externalAttrs}>
                    {entry.data.title}
                    {entry.data.external && <span aria-hidden="true">↗</span>}
                  </a>
                </td>
                <td class="musings__tags" data-label="tags">
                  {entry.data.tags.map((tag) => <span>{tag}</span>)}
                </td>
                <td class="musings__venue" data-label="venue">
                  <span class={`venue venue--${entry.data.venue}`}>{VENUES[entry.data.venue]}</span>
                  {entry.data.research && <span class="research-badge">research</span>}
                </td>
              </tr>
            </>
          );
        })}
        <tr class="musings__empty" data-musing-empty hidden>
          <td colspan="4">no entries match — try a sector chip or clear the search.</td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>('[data-musings]');
  const buttons = Array.from(root?.querySelectorAll<HTMLButtonElement>('[data-filter]') ?? []);
  const rows = Array.from(root?.querySelectorAll<HTMLTableRowElement>('[data-musing-row]') ?? []);
  const dividers = Array.from(root?.querySelectorAll<HTMLTableRowElement>('[data-year-divider]') ?? []);
  const search = root?.querySelector<HTMLInputElement>('[data-msearch]');
  const count = root?.querySelector<HTMLElement>('[data-mcount]');
  const empty = root?.querySelector<HTMLTableRowElement>('[data-musing-empty]');
  const total = rows.length;

  let activeFilter = 'all';

  // full-text body index, lazy-loaded on first search focus (see below)
  let bodyIndex: Record<string, string> | null = null;

  const applyFilters = () => {
    const q = (search?.value || '').trim().toLowerCase();
    let visible = 0;

    rows.forEach((row) => {
      const tags = (row.dataset.tags || '').split('|');
      const matchesTag = activeFilter === 'all' || tags.includes(activeFilter);
      const id = row.dataset.id || '';
      const matchesQuery =
        !q ||
        (row.dataset.search || '').includes(q) ||
        (bodyIndex !== null && (bodyIndex[id] || '').includes(q));
      row.hidden = !(matchesTag && matchesQuery);
      if (!row.hidden) visible++;
    });

    dividers.forEach((divider) => {
      const year = divider.dataset.year;
      divider.hidden = !rows.some((row) => row.dataset.year === year && !row.hidden);
    });

    if (count) count.textContent = visible === total ? `${total} entries` : `${visible} / ${total} entries`;
    if (empty) empty.hidden = visible !== 0;
  };

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      activeFilter = button.dataset.filter || 'all';
      buttons.forEach((b) => {
        const active = b === button;
        b.classList.toggle('is-active', active);
        b.setAttribute('aria-pressed', active ? 'true' : 'false');
      });
      applyFilters();
    });
  });

  search?.addEventListener('input', applyFilters);

  // pull the full-text index the first time the visitor engages search, then
  // re-run so any query already typed now also matches article bodies.
  const loadBodyIndex = async () => {
    if (bodyIndex) return;
    try {
      const res = await fetch('/musings-index.json');
      if (!res.ok) return;
      const arr: Array<{ id: string; text: string }> = await res.json();
      bodyIndex = Object.fromEntries(arr.map((e) => [e.id, e.text]));
      applyFilters();
    } catch {
      /* metadata-only search remains functional */
    }
  };
  search?.addEventListener('focus', loadBodyIndex, { once: true });
</script>

<style>
  .musings {
    display: grid;
    gap: 0.9rem;
  }

  .musings__head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .musings .section-heading {
    margin-bottom: 0;
    font-size: clamp(1.6rem, 3.2vw, 2.6rem);
  }

  .musings__count {
    margin: 0 0 0.25rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.76rem;
  }

  .musings__note {
    margin: -0.2rem 0 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .musings__empty td {
    padding: 2rem 0.55rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .musings__featured {
    display: grid;
    gap: 0.55rem;
  }

  .musings__featured-label {
    margin: 0;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .musings__featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 9.5rem), 1fr));
    gap: 0.55rem;
  }

  .fcard {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
    border-radius: 9px;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    transition: border-color 160ms var(--ease-out), background-color 160ms var(--ease-out);
  }

  .fcard:hover,
  .fcard:focus-visible {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 9%, transparent);
  }

  .fcard__title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-fg);
  }

  .fcard__meta {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--color-muted);
  }

  .musings__search {
    width: min(100%, 320px);
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-surface) 55%, transparent);
    color: var(--color-fg);
    font-family: var(--font-mono);
    /* 16px floor keeps iOS Safari from zooming the page on focus */
    font-size: max(16px, 0.8rem);
  }

  .musings__search::placeholder {
    color: var(--color-muted);
  }

  .musings__search:focus-visible {
    border-color: color-mix(in srgb, var(--color-accent) 58%, var(--color-border));
  }

  .musings__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .mfilter {
    min-height: 30px;
    padding: 0.28rem 0.58rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    transition: background-color 160ms var(--ease-out), border-color 160ms var(--ease-out),
      color 160ms var(--ease-out);
  }

  .mfilter:hover,
  .mfilter:focus-visible,
  .mfilter.is-active {
    border-color: color-mix(in srgb, var(--color-accent) 58%, var(--color-border));
    color: var(--color-accent);
  }

  .mfilter.is-active {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  .musings__table-wrap {
    overflow-x: auto;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .musings__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.88rem;
  }

  .musings__table th,
  .musings__table td {
    padding: 0.62rem 0.55rem;
    text-align: left;
    vertical-align: top;
  }

  .musings__table thead th {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .musings__row {
    border-top: 1px solid var(--color-border);
  }

  .musings__row:hover {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
  }

  .musings__year th {
    padding: 0.78rem 0.55rem 0.38rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
  }

  .musings__date {
    width: 10.5rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .musings__title {
    min-width: 18rem;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .musings__title a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
  }

  .musings__title a:hover,
  .musings__title a:focus-visible {
    color: var(--color-accent);
  }

  .musings__tags {
    width: 18rem;
  }

  .musings__tags span,
  .venue,
  .research-badge {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    padding: 0.22rem 0.46rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.64rem;
    line-height: 1;
    margin: 0 0.35rem 0.35rem 0;
    white-space: nowrap;
  }

  .venue--boiler,
  .research-badge {
    color: var(--color-accent-2);
    border-color: color-mix(in srgb, var(--color-accent-2) 45%, var(--color-border));
  }

  .venue--wagmi {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
  }

  .venue--personal {
    color: var(--color-fg);
  }

  @media (max-width: 720px) {
    /* The block-reflow rules below turn rows into grid/block, which would
       override the [hidden] attribute the filter/search JS toggles. This
       attribute-level selector wins so ANY hidden row stays hidden — rows,
       year dividers, and the empty-state row alike. */
    .musings__table tr[hidden] {
      display: none;
    }

    .musings__head {
      align-items: start;
      flex-direction: column;
      gap: 0.35rem;
    }

    .musings__table-wrap {
      overflow-x: visible;
    }

    .musings__table,
    .musings__table tbody,
    .musings__table tr,
    .musings__table td,
    .musings__table th {
      display: block;
    }

    .musings__table thead {
      display: none;
    }

    .musings__year th {
      padding-left: 0;
    }

    .musings__row {
      display: grid;
      gap: 0.38rem;
      padding: 0.85rem 0;
    }

    .musings__table td {
      width: auto;
      min-width: 0;
      padding: 0;
    }

    .musings__empty td {
      padding: 2rem 0;
    }

    .musings__date::before,
    .musings__title::before,
    .musings__tags::before,
    .musings__venue::before {
      content: attr(data-label);
      display: block;
      margin-bottom: 0.2rem;
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.6rem;
      text-transform: uppercase;
    }

    .musings__title {
      font-size: 1.08rem;
    }
  }
</style>
