---
import type { Project } from '../data/projects';
import { STATUS_LABEL } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const href = project.link ?? project.repo;
const searchIndex = [project.name, project.description, project.stack.join(' '), project.metrics.join(' ')]
  .join(' ')
  .toLowerCase();
---

<details class="prow" data-project-row data-tags={project.tags.join('|')} data-search={searchIndex}>
  <summary class="prow__summary">
    <span class="prow__title">
      <span class="prow__name">{project.name}</span>
      <span class="prow__stack">{project.stack.join(' · ')}</span>
      <span class="prow__since">since {project.since}</span>
    </span>
    <span class={`prow__status status--${project.status}`}>{STATUS_LABEL[project.status]}</span>
  </summary>
  <div class="prow__detail">
    <p class="prow__desc">{project.description}</p>
    <span class="prow__chips">
      {project.metrics.map((metric) => <span class="meta-chip">{metric}</span>)}
    </span>
    {
      href && (
        <a class="inline-link prow__link" href={href} target="_blank" rel="noopener noreferrer">
          view repo ↗
        </a>
      )
    }
  </div>
</details>
