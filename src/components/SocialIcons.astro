---
import Icon from './Icon.astro';
import { SOCIALS, EMAIL_USER } from '../consts';

const links = [
  { name: 'github', href: SOCIALS.github, label: 'GitHub' },
  { name: 'linkedin', href: SOCIALS.linkedin, label: 'LinkedIn' },
  { name: 'x', href: SOCIALS.x, label: 'X' },
] as const;
---

<div class="socials" role="group" aria-label="Contact and social links">
  <a class="socials__link socials__link--resume" href="/resume/">resume</a>
  <a
    class="socials__link"
    data-email-user={EMAIL_USER}
    data-email-domain-a="gm"
    data-email-domain-b="ail"
    data-email-tld="com"
    href="#"
    rel="nofollow"
    aria-label="Email"
  >
    <Icon name="mail" size={18} />
  </a>
  {
    links.map((l) => (
      <a class="socials__link" href={l.href} target="_blank" rel="noopener noreferrer" aria-label={l.label}>
        <Icon name={l.name} size={18} />
      </a>
    ))
  }
</div>

<style>
  .socials {
    display: flex;
    gap: 0.55rem;
  }

  .socials__link {
    display: inline-flex;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 7px;
    color: var(--color-muted);
    transition: color 160ms var(--ease-out), border-color 160ms var(--ease-out);
  }

  .socials__link:hover,
  .socials__link:focus-visible {
    color: var(--color-accent);
    border-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-border));
  }

  .socials__link--resume {
    width: auto;
    padding: 0 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }
</style>

<script>
  document.querySelectorAll('a[data-email-user]').forEach((link) => {
    if (!(link instanceof HTMLAnchorElement)) return;
    const user = link.dataset.emailUser;
    const domain = `${link.dataset.emailDomainA || ''}${link.dataset.emailDomainB || ''}`;
    const tld = link.dataset.emailTld;
    if (user && domain && tld) link.href = `mailto:${user}@${domain}.${tld}`;
  });
</script>
