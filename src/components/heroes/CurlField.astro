---
// Decorative GPU curl-noise flow field (theme-aware).
// Drop inside any `.hero` section; renders a static fallback + WebGL canvas.
// Dark theme: teal particles, additive blend. Light theme: darker ink-teal,
// normal blend, boosted alpha (additive washes out on white).
---

<div class="hero__fallback curl-fallback" aria-hidden="true"></div>
<canvas class="hero__layer curl-canvas" data-curl-canvas aria-hidden="true"></canvas>

<style>
  .curl-fallback {
    opacity: 0.85;
    background:
      radial-gradient(circle at 50% 46%, color-mix(in srgb, var(--color-accent) 16%, transparent), transparent 18rem),
      radial-gradient(circle at 50% 48%, color-mix(in srgb, var(--color-accent-2) 6%, transparent), transparent 26rem);
  }

  .curl-canvas {
    opacity: 0;
    mix-blend-mode: var(--field-mode, screen);
    transition: opacity 600ms var(--ease-out);
  }

  .curl-canvas.is-ready {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .curl-canvas,
    .curl-canvas.is-ready {
      opacity: 0.5;
      transition: none;
    }
  }
</style>

<script>
  import { Geometry, Mesh, Program, Renderer, Vec2, Vec3 } from 'ogl';

  const canvas = document.querySelector('[data-curl-canvas]');
  const root = canvas instanceof HTMLCanvasElement ? canvas.closest('[data-curl-root]') : null;

  if (root instanceof HTMLElement && canvas instanceof HTMLCanvasElement) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let renderer: Renderer | undefined;
    let gl: Renderer['gl'] | undefined;
    let mesh: Mesh | undefined;
    let frame = 0;
    let started = false;
    let visible = false;
    let lastTime = 0;

    const uniforms = {
      uTime: { value: 0 },
      uResolution: { value: new Vec2(1, 1) },
      uPointer: { value: new Vec2(99, 99) },
      uPointerActive: { value: 0 },
      uAlpha: { value: 1 },
      uColor: { value: new Vec3(0.36, 0.92, 0.84) },
      uThemeAlpha: { value: 1 },
    };

    const readField = () => {
      const raw = getComputedStyle(document.documentElement).getPropertyValue('--color-field').trim();
      const parts = raw.split(',').map((s) => parseFloat(s));
      return parts.length === 3 && parts.every((n) => !Number.isNaN(n)) ? parts : [0.36, 0.92, 0.84];
    };

    const applyTheme = () => {
      const theme = document.documentElement.dataset.theme || 'dark';
      const [r, g, b] = readField();
      uniforms.uColor.value.set(r, g, b);
      if (theme === 'light') {
        uniforms.uThemeAlpha.value = 2.4;
        if (gl) gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
      } else {
        uniforms.uThemeAlpha.value = 1;
        if (gl) gl.blendFunc(gl.SRC_ALPHA, gl.ONE);
      }
      if (renderer) render(lastTime);
    };

    const vertex = `
      precision highp float;

      attribute vec2 position;
      attribute float seed;

      uniform float uTime;
      uniform vec2 uResolution;
      uniform vec2 uPointer;
      uniform float uPointerActive;
      uniform float uAlpha;
      uniform float uThemeAlpha;

      varying float vAlpha;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec4 mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec4 permute(vec4 x) { return mod289(((x * 34.0) + 10.0) * x); }
      vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }

      float snoise(vec3 v) {
        const vec2 C = vec2(1.0 / 6.0, 1.0 / 3.0);
        const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);

        vec3 i = floor(v + dot(v, C.yyy));
        vec3 x0 = v - i + dot(i, C.xxx);

        vec3 g = step(x0.yzx, x0.xyz);
        vec3 l = 1.0 - g;
        vec3 i1 = min(g.xyz, l.zxy);
        vec3 i2 = max(g.xyz, l.zxy);

        vec3 x1 = x0 - i1 + C.xxx;
        vec3 x2 = x0 - i2 + C.yyy;
        vec3 x3 = x0 - D.yyy;

        i = mod289(i);
        vec4 p = permute(permute(permute(
          i.z + vec4(0.0, i1.z, i2.z, 1.0))
          + i.y + vec4(0.0, i1.y, i2.y, 1.0))
          + i.x + vec4(0.0, i1.x, i2.x, 1.0));

        float n_ = 0.142857142857;
        vec3 ns = n_ * D.wyz - D.xzx;

        vec4 j = p - 49.0 * floor(p * ns.z * ns.z);
        vec4 x_ = floor(j * ns.z);
        vec4 y_ = floor(j - 7.0 * x_);

        vec4 x = x_ * ns.x + ns.yyyy;
        vec4 y = y_ * ns.x + ns.yyyy;
        vec4 h = 1.0 - abs(x) - abs(y);

        vec4 b0 = vec4(x.xy, y.xy);
        vec4 b1 = vec4(x.zw, y.zw);

        vec4 s0 = floor(b0) * 2.0 + 1.0;
        vec4 s1 = floor(b1) * 2.0 + 1.0;
        vec4 sh = -step(h, vec4(0.0));

        vec4 a0 = b0.xzyw + s0.xzyw * sh.xxyy;
        vec4 a1 = b1.xzyw + s1.xzyw * sh.zzww;

        vec3 p0 = vec3(a0.xy, h.x);
        vec3 p1 = vec3(a0.zw, h.y);
        vec3 p2 = vec3(a1.xy, h.z);
        vec3 p3 = vec3(a1.zw, h.w);

        vec4 norm = taylorInvSqrt(vec4(dot(p0, p0), dot(p1, p1), dot(p2, p2), dot(p3, p3)));
        p0 *= norm.x;
        p1 *= norm.y;
        p2 *= norm.z;
        p3 *= norm.w;

        vec4 m = max(0.6 - vec4(dot(x0, x0), dot(x1, x1), dot(x2, x2), dot(x3, x3)), 0.0);
        m = m * m;
        return 42.0 * dot(m * m, vec4(dot(p0, x0), dot(p1, x1), dot(p2, x2), dot(p3, x3)));
      }

      vec2 curl(vec2 p, float z) {
        float e = 0.18;
        float n1 = snoise(vec3(p.x, p.y + e, z));
        float n2 = snoise(vec3(p.x, p.y - e, z));
        float n3 = snoise(vec3(p.x + e, p.y, z));
        float n4 = snoise(vec3(p.x - e, p.y, z));
        return normalize(vec2(n1 - n2, n4 - n3) + 0.0001);
      }

      void main() {
        vec2 p = position;
        float aspect = uResolution.x / max(uResolution.y, 1.0);
        vec2 flowSpace = vec2(p.x * aspect, p.y) * 1.15;
        float z = uTime * 0.05 + seed * 3.7;
        vec2 c1 = curl(flowSpace * 1.2 + seed, z);
        vec2 c2 = curl(flowSpace * 2.4 - seed, z + 2.0);
        vec2 drift = (c1 * 0.16 + c2 * 0.055) * (0.65 + 0.35 * sin(seed * 21.0 + uTime * 0.16));

        vec2 pointer = uPointer;
        vec2 toParticle = p - pointer;
        toParticle.x *= aspect;
        float influence = smoothstep(0.54, 0.0, length(toParticle)) * uPointerActive;
        drift += normalize(toParticle + 0.0001) * influence * 0.16;

        vec2 finalPos = p + drift;
        gl_Position = vec4(finalPos, 0.0, 1.0);
        gl_PointSize = mix(1.0, 1.65, fract(seed * 17.13));
        vAlpha = (0.05 + 0.07 * fract(seed * 9.31)) * uAlpha * uThemeAlpha;
      }
    `;

    const fragment = `
      precision highp float;
      uniform vec3 uColor;
      varying float vAlpha;

      void main() {
        vec2 p = gl_PointCoord - 0.5;
        float d = dot(p, p);
        float soft = smoothstep(0.25, 0.02, d);
        gl_FragColor = vec4(uColor, vAlpha * soft);
      }
    `;

    const resize = () => {
      if (!renderer || !gl || !mesh) return;
      const width = root.clientWidth;
      const height = root.clientHeight;
      renderer.dpr = Math.min(window.devicePixelRatio || 1, 1.6);
      renderer.setSize(width, height);
      uniforms.uResolution.value.set(width, height);
    };

    const render = (time = 0) => {
      if (!renderer || !mesh) return;
      uniforms.uTime.value = time * 0.001;
      renderer.render({ scene: mesh });
    };

    const loop = (time: number) => {
      frame = 0;
      const shouldRun = visible && !document.hidden && !reduceMotion.matches;
      if (!shouldRun) return;
      lastTime = time;
      render(time);
      frame = window.requestAnimationFrame(loop);
    };

    const startLoop = () => {
      if (frame || reduceMotion.matches) return;
      frame = window.requestAnimationFrame(loop);
    };

    const stopLoop = () => {
      if (!frame) return;
      window.cancelAnimationFrame(frame);
      frame = 0;
    };

    const build = () => {
      if (started) return;
      started = true;
      try {
        renderer = new Renderer({
          canvas,
          alpha: true,
          antialias: false,
          dpr: Math.min(window.devicePixelRatio || 1, 1.6),
        });
        gl = renderer.gl;
        gl.clearColor(0, 0, 0, 0);
        gl.enable(gl.BLEND);
        gl.disable(gl.DEPTH_TEST);

        const area = window.innerWidth * window.innerHeight;
        // coarse pointers (phones/tablets) run a much lower particle floor so the
        // curl-noise vertex shader stays cheap on low-end/small devices.
        const coarse = window.matchMedia('(pointer: coarse)').matches;
        const floor = coarse ? 4000 : 12000;
        const cap = coarse ? 16000 : 40000;
        const count = Math.max(floor, Math.min(cap, Math.floor(area / 62)));
        const positions = new Float32Array(count * 2);
        const seeds = new Float32Array(count);

        for (let i = 0; i < count; i += 1) {
          const r = Math.sqrt(Math.random());
          const a = Math.random() * Math.PI * 2;
          positions[i * 2] = Math.cos(a) * r * 1.18;
          positions[i * 2 + 1] = Math.sin(a) * r * 1.18;
          seeds[i] = Math.random();
        }

        const geometry = new Geometry(gl, {
          position: { size: 2, data: positions },
          seed: { size: 1, data: seeds },
        });

        const program = new Program(gl, {
          vertex,
          fragment,
          uniforms,
          transparent: true,
          depthTest: false,
        });

        mesh = new Mesh(gl, { geometry, program, mode: gl.POINTS });
        applyTheme();
        resize();
        render(reduceMotion.matches ? 0 : performance.now());
        canvas.classList.add('is-ready');
        if (!reduceMotion.matches && visible) startLoop();
      } catch {
        canvas.classList.remove('is-ready');
      }
    };

    const scheduleBuild = () => {
      if (started) return;
      const requestIdle = window.requestIdleCallback || ((callback) => window.setTimeout(callback, 80));
      requestIdle(build, { timeout: 700 });
    };

    const observer = new IntersectionObserver(
      ([entry]) => {
        visible = Boolean(entry?.isIntersecting);
        if (visible) {
          scheduleBuild();
          startLoop();
        } else {
          stopLoop();
        }
      },
      { threshold: 0.02 },
    );

    observer.observe(root);

    window.addEventListener('resize', resize, { passive: true });
    window.addEventListener(
      'pointermove',
      (event) => {
        const rect = root.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
        const y = -(((event.clientY - rect.top) / rect.height) * 2 - 1);
        uniforms.uPointer.value.set(x, y);
        uniforms.uPointerActive.value = 1;
      },
      { passive: true },
    );
    // pointerleave never reaches window listeners (it doesn't bubble); detect
    // the cursor leaving the viewport via pointerout with no relatedTarget.
    document.addEventListener(
      'pointerout',
      (event) => {
        if (!event.relatedTarget) uniforms.uPointerActive.value = 0;
      },
      { passive: true },
    );
    window.addEventListener(
      'scroll',
      () => {
        const fade = Math.max(0, 1 - window.scrollY / Math.max(root.clientHeight, 1));
        canvas.style.opacity = String(fade);
        uniforms.uAlpha.value = fade;
      },
      { passive: true },
    );
    window.addEventListener('themechange', applyTheme);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopLoop();
      else if (visible && !reduceMotion.matches) startLoop();
    });
    reduceMotion.addEventListener('change', () => {
      stopLoop();
      render(lastTime);
      if (!reduceMotion.matches && visible) startLoop();
    });
  }
</script>
